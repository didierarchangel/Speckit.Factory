# 🔑 Speckit.Factory - Clés API
# Renommez ce fichier en .env pour activer les IA

# Google (Gemini)
GOOGLE_API_KEY=votre_cle_ici
# Get one at https://aistudio.google.com/app/apikey

# OpenAI (GPT)
OPENAI_API_KEY=votre_cle_ici

# Anthropic (Claude)
ANTHROPIC_API_KEY=votre_cle_ici

# DeepSeek
DEEPSEEK_API_KEY=votre_cle_ici

# Grok (xAI)
GROK_API_KEY=votre_cle_ici

# OpenRouter (Passerelle universelle avec 100+ modèles - contourne géoblocage)
OPENROUTER_API_KEY=votre_cle_ici
# Get one at https://openrouter.ai/sign-in?redirect_url=https%3A%2F%2Fopenrouter.ai%2Fsettings%2Fkeys
